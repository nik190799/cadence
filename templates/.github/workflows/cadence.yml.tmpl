name: cadence

on:
  push:
    branches: [main]
  pull_request:
  workflow_dispatch:

jobs:
  verify:
    runs-on: ubuntu-latest
    timeout-minutes: 15
    steps:
      - uses: actions/checkout@v6

      - name: Set up Python (for boundary checker)
        uses: actions/setup-python@v6
        with:
          python-version: "3.12"

      - name: Install PyYAML
        run: python -m pip install --quiet pyyaml

      # ---------------------------------------------------------------
      # Replace this block with your stack's runtime setup.
      # Examples (uncomment what applies):
      # ---------------------------------------------------------------
      # - uses: actions/setup-node@v4
      #   with: { node-version: '20' }
      # - run: npm ci
      #
      # - uses: actions/setup-go@v5
      #   with: { go-version: '1.22' }
      #
      # - uses: subosito/flutter-action@v2
      #   with: { channel: 'stable' }
      # - run: flutter pub get
      #
      # - run: rustup toolchain install stable
      # ---------------------------------------------------------------

      - name: Run Cadence verify
        run: bash scripts/verify.sh
